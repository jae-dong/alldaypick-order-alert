
# 텔레그램 주문알림(선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 알림은 텔레그램 전용으로 사용합니다.
# Bot Token과 Chat ID는 GitHub에 올리지 마세요.

# 텔레그램 전송기록 방식 활성화
TELEGRAM_LEDGER=1

# 아래 진단 기능은 평소에는 0으로 유지하세요.
# 기존 데이터 일회성 정리가 꼭 필요할 때만 1로 바꿉니다.
RUN_LEGACY_MIGRATION=0
# 전체 주문문서 진단 조회는 무료 읽기 한도를 사용하므로 평소에는 0입니다.
ENABLE_DIAGNOSTICS=0

# 무료 한도 권장 주기: 신규/발송대기 10분, 전체상태 30분
FAST_POLL_MINUTES=10
POLL_INTERVAL_MINUTES=30
FULL_SYNC_EVERY=4

# 무료 한도 모드에서는 아래 값을 0으로 유지하세요.
