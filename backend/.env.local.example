
# 텔레그램 주문알림(선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 알림은 텔레그램 전용으로 사용합니다.
# Bot Token과 Chat ID는 GitHub에 올리지 마세요.

# 텔레그램 전송기록 방식 활성화
TELEGRAM_LEDGER=1

# 아래 진단 기능은 평소에는 0으로 유지하세요.
# 기존 데이터 일회성 정리가 꼭 필요할 때만 1로 바꿉니다.
RUN_LEGACY_MIGRATION=0
# 전체 주문문서 진단 조회는 무료 읽기 한도를 사용하므로 평소에는 0입니다.
ENABLE_DIAGNOSTICS=0

# 무료 한도 권장 주기: 신규/발송대기 10분, 전체상태 30분
FAST_POLL_MINUTES=10
POLL_INTERVAL_MINUTES=30
FULL_SYNC_EVERY=4

# 무료 한도 모드에서는 아래 값을 0으로 유지하세요.

# 스마트스토어 문의 API는 주문 API와 분리해 60분 간격으로만 조회합니다.
# 429 제한이 발생하면 기본 120분 동안 캐시를 사용합니다.
SMARTSTORE_INQUIRY_INTERVAL_MINUTES=60
SMARTSTORE_INQUIRY_429_COOLDOWN_MINUTES=120

# FINAL v7.7.12 쿠팡 전체상태 보정 범위
# 시작 시 최근 14일의 신규/발송대기/배송중/배송완료를 백그라운드에서 다시 확인합니다.
STARTUP_DEEP_LOOKBACK_DAYS=14
STARTUP_DEEP_MAX_PAGES=8
# 웹앱에서 지금 수집을 누른 경우 더 넓은 범위를 확인합니다.
MANUAL_DEEP_LOOKBACK_DAYS=31
MANUAL_DEEP_MAX_PAGES=10
